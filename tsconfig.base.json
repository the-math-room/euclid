{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@euclid/assessment": ["./packages/assessment/src"],
      "@euclid/document": ["./packages/document/src"],
      "@euclid/geometry": ["./packages/geometry/src"],
      "@euclid/rendering": ["./packages/rendering/src"]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true
  }
}
