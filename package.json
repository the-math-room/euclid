{
  "name": "euclid",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "npm run typecheck:app && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "eslint --cache .",
    "format": "prettier --write --cache .",
    "format:check": "prettier --check --cache .",
    "typecheck": "npm run typecheck:app && npm run typecheck:test",
    "typecheck:app": "tsc -p tsconfig.app.json",
    "typecheck:test": "tsc -p tsconfig.test.json",
    "test": "vitest run",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm run test && vite build",
    "dump-docs": "node scripts/dump-docs.js"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.60.1",
    "vite": "^7.0.0",
    "vitest": "^4.1.8"
  }
}
